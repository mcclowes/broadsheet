{
  "manifest_version": 3,
  "name": "Broadsheet",
  "version": "0.0.1",
  "description": "Save the current tab to Broadsheet.",
  "action": {
    "default_title": "Save to Broadsheet",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },
  "permissions": ["activeTab", "scripting", "storage", "notifications"],
  "host_permissions": ["http://localhost:3000/*"],
  "optional_host_permissions": ["https://*/*"],
  "commands": {
    "save-current-tab": {
      "suggested_key": {
        "default": "Ctrl+Shift+S",
        "mac": "Command+Shift+S"
      },
      "description": "Save current tab to Broadsheet"
    }
  }
}
