{
  "name": "broadsheet",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:prod-smoke": "playwright test --config=playwright.prod-smoke.config.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "extension:icons": "node apps/extension/scripts/generate-icons.mjs",
    "extension:package": "node apps/extension/scripts/package.mjs",
    "extension:release": "node apps/extension/scripts/release.mjs",
    "prepare": "husky"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.2.7",
    "@mozilla/readability": "^0.6.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/blob": "^2.3.3",
    "@vercel/functions": "^3.4.4",
    "diff": "^8.0.4",
    "dompurify": "^3.4.1",
    "folio-db-next": "^0.2.3",
    "jsdom": "29.1.1",
    "marked": "~18.0.2",
    "next": "^16.2.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "resend": "^6.12.2",
    "svix": "^1.92.2",
    "turndown": "^7.2.0",
    "turndown-plugin-gfm": "^1.0.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@clerk/testing": "^2.0.21",
    "@eslint/eslintrc": "^3.3.5",
    "@playwright/test": "^1.59.1",
    "@types/diff": "^8.0.0",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@types/turndown": "^5.0.5",
    "eslint-config-next": "^16.2.4",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "prettier": "^3.8.3",
    "sass": "^1.80.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=20.9.0"
  }
}
