# Clerk — provisioned via Vercel Marketplace (vercel integration add clerk)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Folio article store — adapter selection (see src/lib/folio.ts):
#   1. BROADSHEET_FOLIO_ADAPTER=memory    → ephemeral in-memory (tests only)
#   2. BLOB_READ_WRITE_TOKEN set          → Vercel Blob adapter (production)
#   3. otherwise                          → FsAdapter writing to .broadsheet-data
#      (dev default; override path with BROADSHEET_FS_DIR)
BLOB_READ_WRITE_TOKEN=
# BROADSHEET_FOLIO_ADAPTER=memory
# BROADSHEET_FS_DIR=.broadsheet-data

# Resend — email delivery for the daily digest newsletter
RESEND_API_KEY=
# DIGEST_FROM_EMAIL=Broadsheet <digest@broadsheet.app>

# Vercel Cron — secret to authenticate the daily digest + auto-archive cron jobs
CRON_SECRET=

# Digest unsubscribe token HMAC key. Must NOT be shared with CRON_SECRET: we
# want to rotate one without invalidating the other. Falls back to CRON_SECRET
# if unset (backwards-compat), but set it explicitly for production.
DIGEST_UNSUBSCRIBE_SECRET=

# Base URL — used in email links (no trailing slash)
# NEXT_PUBLIC_BASE_URL=https://broadsheet.app

# Chrome extension IDs allowed to POST to /api/articles (comma-separated).
# If unset in production, all chrome-extension origins are rejected. In
# non-production environments any extension is allowed for local dev.
# BROADSHEET_EXTENSION_IDS=

# Clerk webhook — Svix signing secret for /api/webhooks/clerk.
# Configure a webhook in Clerk Dashboard (endpoint: https://<host>/api/webhooks/clerk),
# subscribe to user.deleted, and paste the signing secret here.
CLERK_WEBHOOK_SIGNING_SECRET=

# Playwright e2e — credentials for a dedicated Clerk test user.
# Create a user in your Clerk development instance and paste its username/email
# and password here. Used by `npm run test:e2e`.
#
# The same variable names are reused by `npm run test:e2e:prod-smoke`
# (the scheduled auth-gated uptime check), but with production Clerk keys and
# a dedicated production test user — see the "Uptime monitoring" section of
# README.md.
E2E_CLERK_USER_USERNAME=
E2E_CLERK_USER_PASSWORD=

# Prod smoke — override the base URL the prod-smoke check hits.
# Defaults to https://broadsheet.app when unset.
# E2E_BASE_URL=
