# Clerk — provisioned via Vercel Marketplace (vercel integration add clerk)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Folio article store
# - Dev: leave unset to use in-memory adapter
# - Prod: set BLOB_READ_WRITE_TOKEN (from Vercel Blob) to persist via folio-db-next blob adapter
BLOB_READ_WRITE_TOKEN=
